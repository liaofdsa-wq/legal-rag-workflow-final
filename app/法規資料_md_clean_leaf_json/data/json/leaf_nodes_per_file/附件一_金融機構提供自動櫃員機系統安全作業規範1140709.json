    ],
    "page_start": 3,
    "page_end": 3,
    "content": "二、 應定期對指定人員(如保全)進行查核。",
    "is_leaf": true,
    "table_count": 0,
    "tables": []
  },
  {
    "file_name": "附件一_金融機構提供自動櫃員機系統安全作業規範1140709.md",
    "node_name": "一、",
