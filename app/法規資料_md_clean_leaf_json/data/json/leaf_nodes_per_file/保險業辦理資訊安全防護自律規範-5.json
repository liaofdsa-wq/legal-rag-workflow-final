    "page_start": 1,
    "page_end": 1,
    "content": "(二)密碼與帳號不應相同。",
    "is_leaf": true,
    "table_count": 0,
    "tables": []
  },
  {
    "file_name": "保險業辦理資訊安全防護自律規範-5.md",
    "node_name": "(三)",
    "level": 1,
    "sibling_order": 3,
    "path_key": "4.3",
    "path_names": [
